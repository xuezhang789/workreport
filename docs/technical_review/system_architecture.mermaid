graph TD
    User((User))
    
    subgraph Core [Core Module]
        Auth[Auth & Profile]
        RBAC[RBAC Permission]
        Upload[File Upload]
        Settings[System Settings]
    end
    
    subgraph Audit [Audit Module]
        Log[Audit Log]
        History[Task History]
    end
    
    subgraph Projects [Projects Module]
        Proj[Project Mgmt]
        Member[Member Mgmt]
    end
    
    subgraph Tasks [Tasks Module]
        Task[Task Mgmt]
        SLA[SLA Engine]
        State[State Machine]
    end
    
    subgraph Reports [Reports & WorkLogs]
        Daily[Daily Report]
        Stats[Performance Stats]
        Notify[Notification]
    end
    
    User --> Auth
    User --> Daily
    User --> Task
    User --> Proj
    
    Proj --> RBAC
    Proj --> Log
    
    Task --> Proj
    Task --> SLA
    Task --> Log
    
    Daily --> Proj
    Daily --> Task
    
    Stats --> Task
    Stats --> Daily
    
    Upload --> Core
    Notify --> Core
